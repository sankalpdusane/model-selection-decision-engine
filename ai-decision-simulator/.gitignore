# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Environment variables — NEVER commit these ───────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Database files ───────────────────────────────────────────────────────────
# SQLite DB is runtime state, not source code
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
decisions.db

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / Editor artefacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ── Misc ─────────────────────────────────────────────────────────────────────
.turbo
